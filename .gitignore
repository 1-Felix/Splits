# Secrets — never commit
.env
.garmin_tokens
.garmin_tokens/

# Raw Garmin API response cache (telemetry; regenerated each day)
.garmin_cache/

# Real telemetry written by sync_garmin.py — personal health data, kept local.
# A fresh clone without this file renders the dashboard's built-in demo data
# until `python sync_garmin.py` regenerates it.
garmin-data.js

# The live plan — coach-owned, lives in the data volume (seeded from
# plan-data.default.js on first container boot). The default is what ships.
plan-data.js

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

