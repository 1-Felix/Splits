<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ============================================================= -->
    <!-- Health Connect READ permissions (record-type scoped)          -->
    <!-- ============================================================= -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_SPEED" />
    <uses-permission android:name="android.permission.health.READ_ELEVATION_GAINED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />

    <!-- Special-access permissions (backfill / background sync).              -->
    <!-- READ_HEALTH_DATA_HISTORY  -> data older than 30 days.                 -->
    <!-- READ_HEALTH_DATA_IN_BACKGROUND -> reads while app not in foreground.  -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_HISTORY" />
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND" />

    <!-- Push runs to the SPLITS ingest endpoint. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ============================================================= -->
    <!-- Package visibility: needed to detect / talk to the Health     -->
    <!-- Connect provider and to receive the rationale intent.         -->
    <!-- ============================================================= -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <!-- usesCleartextTraffic: the ingest transport is a private LAN/tailnet   -->
    <!-- (http://100.x / http://192.168.x) until 5.3 lands a TLS path; https   -->
    <!-- URLs work unchanged.                                                  -->
    <application
        android:allowBackup="false"
        android:icon="@android:drawable/ic_menu_compass"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.SplitsSpike">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Pre-Android 14 (Health Connect as a standalone APK): the provider  -->
            <!-- launches this action to show the app's permission rationale.       -->
            <intent-filter>
                <action android:name="androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Android 14+ (Health Connect built into the platform, incl. Android 16):  -->
        <!-- the privacy-policy / permission-usage entry point Health Connect links    -->
        <!-- to from the permission screen. Must be exported and permission-guarded.   -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>
</manifest>
