# Garmin Connect credentials for sync_garmin.py
# Copy this file to ".env" and fill in your real values. NEVER commit ".env".

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password

# If your account uses multi-factor auth: put the current 6-digit code here so a
# non-interactive run can complete. Tokens are cached after the first login, so
# you only need this once (clear it afterwards).
# GARMIN_MFA=

# Where to cache the auth token so you don't log in every run (dir is created).
# Used by a local `python sync_garmin.py`; in Docker the token lives in the volume.
GARMIN_TOKENSTORE=.garmin_tokens

# ── Docker / self-host (read by docker-compose.yml via ${VAR} substitution) ──
# TZ=Europe/Berlin        # your timezone — drives the live clock + nightly sync
# SYNC_AT=04:00           # daily auto-sync time (local); "off" to disable

# Optional profile overrides — Garmin doesn't always expose these cleanly.
# ATHLETE_NAME=Felix
# ATHLETE_AGE=31
# ATHLETE_MAX_HR=197
